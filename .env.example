# GraphMem Configuration
# Copy this to .env and fill in your values

# Graph Database (kuzu or neo4j)
GRAPHMEM_DB_BACKEND=kuzu
GRAPHMEM_DB_PATH=~/.graphmem/db

# Neo4j (only if GRAPHMEM_DB_BACKEND=neo4j)
# GRAPHMEM_NEO4J_URI=bolt://localhost:7687
# GRAPHMEM_NEO4J_USER=neo4j
# GRAPHMEM_NEO4J_PASSWORD=password

# Embedding Provider (bedrock, openai, or local)
GRAPHMEM_EMBEDDER=openai

# LLM Provider for entity extraction (bedrock, anthropic, openai, or ollama)
GRAPHMEM_LLM=openai

# OpenAI (if using openai embedder or llm)
# OPENAI_API_KEY=sk-...

# Anthropic (if using anthropic llm)
# ANTHROPIC_API_KEY=sk-ant-...

# AWS Bedrock (if using bedrock embedder or llm)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# GRAPHMEM_BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
# GRAPHMEM_BEDROCK_LLM_MODEL=anthropic.claude-sonnet-4-20250514

# Ollama (if using ollama llm)
# GRAPHMEM_OLLAMA_BASE_URL=http://localhost:11434
# GRAPHMEM_OLLAMA_MODEL=llama3.2

# Local embeddings (if using local embedder)
# GRAPHMEM_LOCAL_EMBED_MODEL=all-MiniLM-L6-v2
